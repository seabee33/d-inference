#!/usr/bin/env bash
#
# Pre-push hook for d-inference.
# Runs the same checks as CI before pushing to catch failures locally.
#
# Install: git config core.hooksPath .githooks
#

set -euo pipefail

FAILED=0

# Check which components have changes being pushed.
# Compare local HEAD against the remote ref being pushed to.
REMOTE="$1"
RANGE=""
while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue  # deleting branch
    fi
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        RANGE="$local_sha"  # new branch
    else
        RANGE="$remote_sha..$local_sha"
    fi
done

if [ -z "$RANGE" ]; then
    exit 0
fi

CHANGED_FILES=$(git diff --name-only "$RANGE" 2>/dev/null || git diff --name-only HEAD~1)

HAS_GO=$(echo "$CHANGED_FILES" | grep -q '^coordinator/' && echo 1 || echo 0)
HAS_TS=$(echo "$CHANGED_FILES" | grep -q '^console-ui/' && echo 1 || echo 0)

# ---------------------------------------------------------------------------
# Go — formatting + tests
# ---------------------------------------------------------------------------
if [ "$HAS_GO" = "1" ]; then
    echo ">> [pre-push] Go formatting check..."
    UNFORMATTED=$(cd coordinator && gofmt -l . 2>/dev/null || true)
    if [ -n "$UNFORMATTED" ]; then
        echo "ERROR: Unformatted Go files:"
        echo "$UNFORMATTED" | sed 's/^/  /'
        echo "Fix with: cd coordinator && gofmt -w ."
        FAILED=1
    fi

    echo ">> [pre-push] Go tests..."
    # Skip internal/api — its WebSocket integration tests are slow (~5 min) and
    # timing-sensitive. They run in CI instead.
    if ! (cd coordinator && go test $(go list ./... | grep -v /internal/api) 2>&1 | tail -15); then
        echo "ERROR: Go tests failed."
        FAILED=1
    fi
fi

# ---------------------------------------------------------------------------
# TypeScript — lint + build
# ---------------------------------------------------------------------------
if [ "$HAS_TS" = "1" ]; then
    echo ">> [pre-push] TypeScript lint check..."
    if ! (cd console-ui && npx eslint --quiet src/ 2>&1 | tail -10); then
        echo "ERROR: TypeScript lint failed. Fix with: cd console-ui && npx eslint --fix src/"
        FAILED=1
    fi

    echo ">> [pre-push] Next.js build check..."
    if ! (cd console-ui && npm run build 2>&1 | tail -10); then
        echo "ERROR: Next.js build failed."
        FAILED=1
    fi
fi

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo "Pre-push checks failed. Fix the issues above before pushing."
    exit 1
fi

echo ">> [pre-push] All checks passed."
