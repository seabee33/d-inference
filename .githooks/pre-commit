#!/usr/bin/env bash
#
# Pre-commit hook for d-inference.
# Checks formatting on staged files only. Skips checks when no relevant files are staged.
#
# Install: git config core.hooksPath .githooks
#

set -euo pipefail

FAILED=0

# ---------------------------------------------------------------------------
# Go — gofmt on staged .go files under coordinator/
# ---------------------------------------------------------------------------
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM -- 'coordinator/**.go' | grep '\.go$' || true)

if [ -n "$GO_FILES" ]; then
    echo ">> Checking Go formatting (gofmt)..."
    UNFORMATTED=$(gofmt -l $GO_FILES 2>/dev/null || true)
    if [ -n "$UNFORMATTED" ]; then
        echo ""
        echo "ERROR: The following Go files need formatting:"
        echo "$UNFORMATTED" | sed 's/^/  /'
        echo ""
        echo "Fix with:  gofmt -w <file>  (or run: gofmt -w \$(git diff --cached --name-only -- 'coordinator/**.go'))"
        echo ""
        FAILED=1
    fi
fi

# ---------------------------------------------------------------------------
# TypeScript — next lint in console-ui/ if any .ts/.tsx files are staged
# ---------------------------------------------------------------------------
TS_FILES=$(git diff --cached --name-only --diff-filter=ACM -- 'console-ui/**.ts' 'console-ui/**.tsx' | grep -E '\.(ts|tsx)$' || true)

if [ -n "$TS_FILES" ]; then
    echo ">> Checking TypeScript lint (eslint)..."
    if ! (cd console-ui && npx eslint src/ 2>/dev/null); then
        echo ""
        echo "ERROR: TypeScript lint errors in console-ui/."
        echo ""
        echo "Fix with:  cd console-ui && npx eslint --fix src/"
        echo ""
        FAILED=1
    fi
fi

# ---------------------------------------------------------------------------
# Swift — skipped (no standard enforced formatter)
# ---------------------------------------------------------------------------

if [ "$FAILED" -ne 0 ]; then
    echo "Pre-commit checks failed. Please fix the issues above and try again."
    exit 1
fi
