    {
      "definition": {
        "type": "group",
        "title": "System Metrics (Host)",
        "layout_type": "ordered",
        "show_title": true,
        "widgets": [
          {
            "definition": {
              "type": "timeseries",
              "title": "CPU Usage",
              "show_legend": true,
              "legend_layout": "auto",
              "yaxis": {
                "label": "%",
                "min": "0",
                "max": "100"
              },
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
